# Copy to `.env` for local testing:  node --env-file=.env index.js
# (Node 20.6+ supports --env-file. Never commit your real .env.)

# GitHub user to track
GH_USERNAME=xn1781

# GitHub Personal Access Token (classic) with the read-only `read:user` scope.
# Needed for the contribution graph / streak. Create at:
# https://github.com/settings/tokens
GH_TOKEN=

# Discord application identity credentials
DISCORD_APP_ID=
DISCORD_USER_ID=
DISCORD_BOT_TOKEN=

# Optional: text shown on the widget; keep in sync with the cron schedule
UPDATE_LABEL=updates every 30 min
